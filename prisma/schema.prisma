generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id               String           @id @default(cuid())
  email            String?          @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  password         String?
  drinkingCapacity DrinkingCapacity @default(MEDIUM)
  sweetPref        Float            @default(0.5)
  sourPref         Float            @default(0.5)
  bitterPref       Float            @default(0.5)
  strongPref       Float            @default(0.5)
  freshPref        Float            @default(0.5)
  pantry           String[]         @default([])
  accounts         Account[]
  sessions         Session[]
  emotionLogs      EmotionLog[]
  recommendations  Recommendation[]
  customCocktails  Cocktail[]       @relation("UserCustomCocktails")
  refreshTokens    RefreshToken[]
  createdAt        DateTime         @default(now())
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmotionLog {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  joy             Float    @default(0)
  sadness         Float    @default(0)
  stress          Float    @default(0)
  fatigue         Float    @default(0)
  excitement      Float    @default(0)
  rawText         String?  @db.Text
  createdAt       DateTime @default(now())
}

model Cocktail {
  id              String               @id @default(cuid())
  name            String
  nameEn          String?
  description     String?              @db.Text
  category        String?
  glassType       String?
  method          String?
  sweetness       Float                @default(0)
  sourness        Float                @default(0)
  bitterness      Float                @default(0)
  strength        Float                @default(0)
  freshness       Float                @default(0)
  abv             Float                @default(0)
  popularity      Float                @default(0.5)
  imageUrl        String?
  isCustom        Boolean              @default(false)
  createdBy       String?
  creator         User?                @relation("UserCustomCocktails", fields: [createdBy], references: [id], onDelete: SetNull)
  ingredients     CocktailIngredient[]
  recommendations Recommendation[]
}

model Ingredient {
  id       String               @id @default(cuid())
  name     String               @unique
  nameEn   String?
  category String?
  abv      Float                @default(0)
  cocktails CocktailIngredient[]
}

model CocktailIngredient {
  id           String     @id @default(cuid())
  cocktailId   String
  ingredientId String
  amount       String?
  cocktail     Cocktail   @relation(fields: [cocktailId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
}

model Recommendation {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  cocktailId   String
  cocktail     Cocktail @relation(fields: [cocktailId], references: [id])
  score        Float
  emotionLogId String?
  liked        Boolean?
  createdAt    DateTime @default(now())
}

model Bar {
  id           String    @id @default(cuid())
  name         String
  address      String
  area         String?
  moodTags     String[]
  signature    String?
  imageUrl     String?
  latitude     Float?
  longitude    Float?
  description  String?   @db.Text
  placeId      String?   @unique
  rating       Float?
  priceLevel   Int?
  reviewCount  Int?
  purposeTags  String[]
  analyzedAt   DateTime?
  createdAt    DateTime  @default(now())
}

enum DrinkingCapacity {
  LOW
  MEDIUM
  HIGH
}
